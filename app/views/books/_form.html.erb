<%= tag.div(flash[:alert], class: "flash alert") if flash[:alert] %>

<% if book.errors.any? %>
  <div class="errors">
    <ul>
      <% book.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: book do |form| %>
  <div class="field">
    <%= form.label :title %>
    <%= form.text_field :title, required: true %>
  </div>

  <div class="field">
    <%= form.label :author %>
    <%= form.text_field :author, required: true %>
  </div>

  <div class="field">
    <%= form.label :description %>
    <%= form.text_area :description %>
  </div>

  <div class="field">
    <%= form.label :genre_ids, "Genres" %>
    <ul class="checkbox-list">
      <%= form.collection_check_boxes :genre_ids, Genre.order(:name), :id, :name do |b| %>
        <li>
          <%= b.label do %>
            <%= b.check_box %>
            <%= b.text %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>

  <%= form.submit %>
<% end %>
