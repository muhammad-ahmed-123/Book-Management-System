<% content_for :title, @book.title %>

<%= tag.div(flash[:alert], style: "color:red") if flash[:alert] %>
<%= tag.div(flash[:notice], style: "color:green") if flash[:notice] %>

<h1><%= @book.title %></h1>
<p>by <%= @book.author %></p>
<p><%= simple_format(@book.description) if @book.description.present? %></p>
<p>
  Genres:
  <% if @book.genres.any? %>
    <%= @book.genres.order(:name).pluck(:name).join(", ") %>
  <% else %>
    <em>None</em>
  <% end %>
</p>

<% if Current.user == @book.user %>
  <%= link_to "Edit", edit_book_path(@book) %>
  <%= button_to "Delete", @book, method: :delete, data: { confirm: "Are you sure?" } %>
<% end %>

<h2>Reviews</h2>

<% if @reviews.any? %>
  <%= render @reviews %>
<% else %>
  <p>No reviews yet.</p>
<% end %>

<% if authenticated? %>
  <% if Current.user == @book.user %>
    <p><em>You can't review your own book.</em></p>
  <% elsif @current_user_review %>
    <%= link_to "Edit your review", edit_book_review_path(@book, @current_user_review) %>
  <% else %>
    <%= link_to "Write a Review", new_book_review_path(@book) %>
  <% end %>
<% end %>

<%= link_to "Back to Books", books_path %>
