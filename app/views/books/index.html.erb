<% content_for :title, "Books" %>

<%= tag.div(flash[:alert], class: "flash alert") if flash[:alert] %>
<%= tag.div(flash[:notice], class: "flash notice") if flash[:notice] %>

<% unless authenticated? %>
  <section class="hero">
    <h1 class="hero__title">Track every book you read, <em>reviewed by us.</em></h1>
    <p class="hero__subtitle">Marginalia helps you catalog books, organize them by genre, and share honest reviews with a community of readers.</p>
    <div class="hero__actions">
      <%= link_to "Sign Up", new_registration_path, class: "btn btn-primary" %>
      <%= link_to "Sign In", new_session_path, class: "btn" %>
    </div>
  </section>
<% end %>

<p class="section-label">All books</p>

<ul class="book-grid">
  <% @books.each do |book| %>
    <li class="book-card">
      <h3><%= link_to book.title, book %></h3>
      <p>by <%= book.author %></p>
      <% if book.genres.any? %>
        <div class="genre-tags">
          <% book.genres.order(:name).each do |genre| %>
            <span class="genre-tag"><%= genre.name %></span>
          <% end %>
        </div>
      <% end %>
      <% if authenticated? %>
        <div class="book-favourite">
          <%= render "favourites/toggle_button", book: book, favourited: @favourited_book_ids.include?(book.id) %>
        </div>
      <% end %>
      <% if Current.user == book.user %>
        <div class="book-actions">
          <%= link_to "Edit", edit_book_path(book), class: "btn" %>
          <%= button_to "Delete", book, method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger" %>
        </div>
      <% end %>
    </li>
  <% end %>
</ul>
