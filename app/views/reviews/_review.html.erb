<div>
  <strong><%= review.rating %>/5</strong> — <%= review.user.email_address %>
  <p><%= simple_format(review.body) %></p>
  <% if Current.user == review.user %>
    <%= link_to "Edit your review", edit_book_review_path(review.book, review) %>
    <%= button_to "Delete your review", book_review_path(review.book, review), method: :delete, data: { confirm: "Are you sure?" } %>
  <% end %>
</div>
